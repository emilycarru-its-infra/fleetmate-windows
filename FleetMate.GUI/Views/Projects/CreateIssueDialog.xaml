<Window x:Class="FleetMate.GUI.Views.Projects.CreateIssueDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        ui:WindowHelper.UseModernWindowStyle="True"
        Title="Create GitHub Issue"
        Height="520" Width="520"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" Text="New GitHub Issue" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,16" />

        <!-- Form -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Repository -->
                <TextBlock Text="Repository (owner/repo)" FontWeight="SemiBold" Margin="0,0,0,4" />
                <TextBox x:Name="RepoBox" Margin="0,0,0,12" />

                <!-- Title -->
                <TextBlock Text="Title" FontWeight="SemiBold" Margin="0,0,0,4" />
                <TextBox x:Name="TitleBox" Margin="0,0,0,12" />

                <!-- Body (Markdown) -->
                <TextBlock Text="Body (Markdown)" FontWeight="SemiBold" Margin="0,0,0,4" />
                <TextBox x:Name="BodyBox" AcceptsReturn="True" TextWrapping="Wrap"
                         MinHeight="120" MaxHeight="200" VerticalScrollBarVisibility="Auto"
                         FontFamily="Cascadia Code, Consolas" FontSize="12" Margin="0,0,0,12" />

                <!-- Labels -->
                <TextBlock Text="Labels (comma-separated)" FontWeight="SemiBold" Margin="0,0,0,4" />
                <TextBox x:Name="LabelsBox" Margin="0,0,0,12" />

                <!-- Assignees -->
                <TextBlock Text="Assignees (comma-separated usernames)" FontWeight="SemiBold" Margin="0,0,0,4" />
                <TextBox x:Name="AssigneesBox" Margin="0,0,0,12" />
            </StackPanel>
        </ScrollViewer>

        <!-- Actions -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <TextBlock x:Name="StatusText" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                       VerticalAlignment="Center" Margin="0,0,16,0" />
            <Button Content="Cancel" Click="OnCancel" Margin="0,0,8,0" MinWidth="80" />
            <Button x:Name="CreateButton" Content="Create Issue" Click="OnCreate"
                    Style="{StaticResource AccentButtonStyle}" MinWidth="100" />
        </StackPanel>
    </Grid>
</Window>
