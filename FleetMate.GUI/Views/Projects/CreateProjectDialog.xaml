<Window x:Class="FleetMate.GUI.Views.Projects.CreateProjectDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        ui:WindowHelper.UseModernWindowStyle="True"
        Title="Create GitHub Project"
        Height="280" Width="440"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" Text="New GitHub Project (v2)" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,16" />

        <!-- Form -->
        <StackPanel Grid.Row="1">
            <!-- Title -->
            <TextBlock Text="Project Title" FontWeight="SemiBold" Margin="0,0,0,4" />
            <TextBox x:Name="TitleBox" Margin="0,0,0,12" />

            <!-- Owner Scope -->
            <TextBlock Text="Owner Scope" FontWeight="SemiBold" Margin="0,0,0,4" />
            <ComboBox x:Name="ScopeCombo" SelectedIndex="0" HorizontalAlignment="Stretch" Margin="0,0,0,12">
                <ComboBoxItem Content="Organization" Tag="org" />
                <ComboBoxItem Content="User (personal)" Tag="user" />
            </ComboBox>
        </StackPanel>

        <!-- Actions -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <TextBlock x:Name="StatusText" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                       VerticalAlignment="Center" Margin="0,0,16,0" />
            <Button Content="Cancel" Click="OnCancel" Margin="0,0,8,0" MinWidth="80" />
            <Button x:Name="CreateButton" Content="Create Project" Click="OnCreate"
                    Style="{StaticResource AccentButtonStyle}" MinWidth="100" />
        </StackPanel>
    </Grid>
</Window>
