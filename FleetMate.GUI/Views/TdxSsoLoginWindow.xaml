<ui:Window x:Class="FleetMate.GUI.Views.TdxSsoLoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="Sign in to TeamDynamix"
        Width="700" Height="700"
        MinWidth="500" MinHeight="500"
        WindowStartupLocation="CenterOwner"
        Style="{StaticResource DefaultWindowStyle}">
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Header -->
        <Border Grid.Row="0" Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}" Padding="16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Sign in to TeamDynamix" 
                               Style="{StaticResource SubtitleTextBlockStyle}"
                               FontWeight="SemiBold"/>
                    <TextBlock Text="Authenticate with your organization's identity provider"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                               Margin="0,4,0,0"/>
                </StackPanel>
                
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <ui:ProgressRing x:Name="LoadingIndicator" 
                                     Width="20" Height="20" 
                                     Visibility="Collapsed"
                                     Margin="0,0,12,0"/>
                    <Button x:Name="CancelButton" 
                            Content="Cancel"
                            Click="CancelButton_Click"/>
                </StackPanel>
            </Grid>
        </Border>
        
        <!-- WebView -->
        <Grid Grid.Row="1">
            <!-- Loading state -->
            <StackPanel x:Name="LoadingPanel" 
                        HorizontalAlignment="Center" 
                        VerticalAlignment="Center"
                        Visibility="Visible">
                <ui:ProgressRing IsActive="True" Width="48" Height="48"/>
                <TextBlock Text="Loading SSO login..." 
                           TextAlignment="Center"
                           Margin="0,16,0,0"
                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
            </StackPanel>
            
            <!-- Error state -->
            <StackPanel x:Name="ErrorPanel" 
                        HorizontalAlignment="Center" 
                        VerticalAlignment="Center"
                        Visibility="Collapsed">
                <ui:FontIcon Glyph="&#xE7BA;" FontSize="48" 
                             Foreground="{DynamicResource SystemFillColorCautionBrush}"/>
                <TextBlock Text="Authentication Error" 
                           Style="{StaticResource SubtitleTextBlockStyle}"
                           TextAlignment="Center"
                           Margin="0,16,0,8"/>
                <TextBlock x:Name="ErrorMessage" 
                           TextAlignment="Center"
                           TextWrapping="Wrap"
                           MaxWidth="400"
                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                <StackPanel Orientation="Horizontal" 
                            HorizontalAlignment="Center"
                            Margin="0,16,0,0">
                    <Button x:Name="RetryButton" 
                            Content="Try Again" 
                            Style="{StaticResource AccentButtonStyle}"
                            Click="RetryButton_Click"
                            Margin="0,0,8,0"/>
                    <Button Content="Cancel" Click="CancelButton_Click"/>
                </StackPanel>
            </StackPanel>
            
            <!-- WebView2 control -->
            <wv2:WebView2 x:Name="WebView" 
                          Visibility="Collapsed"/>
        </Grid>
        
        <!-- Status bar -->
        <Border Grid.Row="2" 
                Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}" 
                Padding="8,4">
            <TextBlock x:Name="StatusText" 
                       Text="Initializing..."
                       Style="{StaticResource CaptionTextBlockStyle}"
                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
        </Border>
    </Grid>
</ui:Window>
