<Page x:Class="FleetMate.GUI.Views.DashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.modernwpf.com/2019"
      xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF">

    <ScrollViewer Padding="16">
        <StackPanel>
            <!-- Header -->
            <DockPanel Margin="0,0,0,6">
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Top">
                    <ui:ProgressRing x:Name="HeaderProgress" IsActive="True" Width="18" Height="18" 
                                     Margin="0,0,8,0" Visibility="Collapsed" />
                    <Button Content="Refresh" Click="OnRefreshClicked" Margin="0,0,8,0" />
                    <Button Content="Authentication" Click="OnAuthClicked" />
                </StackPanel>
                <StackPanel>
                    <TextBlock Text="Dashboard" Style="{StaticResource TitleTextStyle}" Margin="0,0,0,2" />
                    <TextBlock Text="Fleet overview across all connected systems" Style="{StaticResource SubtitleTextStyle}" />
                </StackPanel>
            </DockPanel>

            <!-- Error Banner -->
            <Border x:Name="ErrorBanner" Visibility="Collapsed" Background="#33FF6600" CornerRadius="4" Padding="12,8" Margin="0,0,0,8">
                <DockPanel>
                    <Button DockPanel.Dock="Right" Content="Dismiss" Click="OnDismissErrorClicked" 
                            VerticalAlignment="Center" Margin="12,0,0,0" />
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <ui:FontIcon Glyph="&#xE7BA;" FontSize="16" Margin="0,0,8,0" />
                        <TextBlock x:Name="ErrorBannerText" TextWrapping="Wrap" 
                                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- Alert Pills -->
            <WrapPanel x:Name="AlertPillsPanel" Margin="0,0,0,8" />

            <!-- Loading indicator -->
            <StackPanel x:Name="LoadingPanel" Orientation="Horizontal" Margin="0,0,0,8" Visibility="Collapsed">
                <ui:ProgressRing IsActive="True" Width="20" Height="20" />
                <TextBlock Text="Loading dashboard data..." Margin="8,0,0,0" VerticalAlignment="Center"
                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
            </StackPanel>

            <!-- Connect Services Prompt -->
            <Border x:Name="ConnectServicesPrompt" Visibility="Collapsed" Style="{StaticResource CardStyle}" Margin="0,0,0,12">
                <StackPanel HorizontalAlignment="Center" Margin="24">
                    <ui:FontIcon Glyph="&#xE968;" FontSize="36" HorizontalAlignment="Center" Margin="0,0,0,8" />
                    <TextBlock Text="No services connected yet" FontSize="16" FontWeight="SemiBold" HorizontalAlignment="Center" />
                    <TextBlock Text="Configure your systems in Settings to see fleet data here."
                               HorizontalAlignment="Center" Margin="0,4,0,0"
                               Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                </StackPanel>
            </Border>

            <!-- KPI Strip -->
            <WrapPanel x:Name="KpiStrip" Margin="0,0,0,10" />

            <!-- Main content: Charts (left) + Activity Feed (right) -->
            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Left: Flowing chart cards -->
                <WrapPanel x:Name="ChartGrid" Grid.Column="0" Margin="0,0,12,0" />

                <!-- Right: Activity Feed -->
                <StackPanel Grid.Column="1">
                    <TextBlock Text="Recent Activity" Style="{StaticResource SectionHeaderStyle}" Margin="0,0,0,6" />
                    <Border Style="{StaticResource CardStyle}">
                        <ItemsControl x:Name="ActivityFeed">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}" 
                                            BorderThickness="0,0,0,0.5" Padding="0,4" Cursor="Hand"
                                            MouseLeftButtonUp="OnActivityItemClicked" Tag="{Binding Tab}">
                                        <DockPanel>
                                            <TextBlock Text="{Binding Time}" DockPanel.Dock="Right" FontSize="10"
                                                       VerticalAlignment="Center" Margin="8,0,0,0"
                                                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                <ui:FontIcon Glyph="{Binding IconGlyph}" FontSize="12" Margin="0,0,6,0"
                                                             Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                                                <TextBlock Text="{Binding Text}" FontSize="12" TextTrimming="CharacterEllipsis" />
                                            </StackPanel>
                                        </DockPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                            <ItemsControl.Style>
                                <Style TargetType="ItemsControl">
                                    <Style.Triggers>
                                        <Trigger Property="HasItems" Value="False">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate>
                                                        <TextBlock Text="Activity will appear once data loads." Padding="0,8"
                                                                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </ItemsControl.Style>
                        </ItemsControl>
                    </Border>
                </StackPanel>
            </Grid>

        </StackPanel>
    </ScrollViewer>
</Page>
