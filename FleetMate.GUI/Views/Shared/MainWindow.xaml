<Window x:Class="FleetMate.GUI.Views.Shared.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        xmlns:vm="clr-namespace:FleetMate.GUI.ViewModels"
        ui:WindowHelper.UseModernWindowStyle="True"
        ui:TitleBar.ExtendViewIntoTitleBar="True"
        Title="FleetMate"
        Height="700"
        Width="1100"
        MinHeight="500"
        MinWidth="900"
        WindowStartupLocation="CenterScreen">

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Top Tab Bar -->
        <Border Grid.Row="0" Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}" Padding="12,8">
            <StackPanel Orientation="Horizontal" x:Name="TabBar">
                <RadioButton x:Name="TabDashboard" Content="Dashboard" Tag="Dashboard" GroupName="MainTabs"
                             IsChecked="True" Checked="OnTabChecked" Style="{StaticResource {x:Type RadioButton}}" Margin="0,0,4,0" FontSize="13" />
                <RadioButton x:Name="TabDevices" Content="Devices" Tag="Devices" GroupName="MainTabs"
                             Checked="OnTabChecked" Margin="0,0,4,0" FontSize="13" />
                <RadioButton x:Name="TabInventory" Content="Inventory" Tag="Inventory" GroupName="MainTabs"
                             Checked="OnTabChecked" Margin="0,0,4,0" FontSize="13" />
                <RadioButton x:Name="TabTickets" Content="Tickets" Tag="Tickets" GroupName="MainTabs"
                             Checked="OnTabChecked" Margin="0,0,4,0" FontSize="13" />
                <RadioButton x:Name="TabBoards" Content="Projects" Tag="Projects" GroupName="MainTabs"
                             Checked="OnTabChecked" Margin="0,0,4,0" FontSize="13" />
                <RadioButton x:Name="TabIdentity" Content="Identity" Tag="Identity" GroupName="MainTabs"
                             Checked="OnTabChecked" Margin="0,0,4,0" FontSize="13" />
                <RadioButton x:Name="TabSettings" Content="⚙ Settings" Tag="Settings" GroupName="MainTabs"
                             Checked="OnTabChecked" Margin="16,0,0,0" FontSize="13" />
            </StackPanel>
        </Border>

        <Separator Grid.Row="1" />

        <!-- Content Frame -->
        <Frame Grid.Row="2" x:Name="ContentFrame" NavigationUIVisibility="Hidden" Background="Transparent" />
    </Grid>
</Window>
