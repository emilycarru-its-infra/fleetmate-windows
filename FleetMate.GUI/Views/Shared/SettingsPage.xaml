<Page x:Class="FleetMate.GUI.Views.Shared.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.modernwpf.com/2019">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24" MaxWidth="800">
            <TextBlock Text="Settings" Style="{StaticResource TitleTextStyle}" />
            <TextBlock Text="Configure FleetMate" Style="{StaticResource SubtitleTextStyle}" Margin="0,0,0,24" />

            <!-- Configuration File -->
            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Configuration" FontWeight="SemiBold" FontSize="16" Margin="0,0,0,8" />
                    <TextBlock Text="Config file location:" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                    <TextBox x:Name="ConfigPathTextBox" IsReadOnly="True" Margin="0,4,0,0"
                             Text="~/.fleetmate/config.yaml" />
                </StackPanel>
            </Border>

            <!-- Graph API Settings -->
            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Microsoft Graph" FontWeight="SemiBold" FontSize="16" Margin="0,0,0,8" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Column="0" Grid.Row="0" Margin="0,0,8,8">
                            <TextBlock Text="Tenant ID" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                            <TextBox x:Name="TenantIdTextBox" Margin="0,4,0,0" />
                        </StackPanel>

                        <StackPanel Grid.Column="1" Grid.Row="0" Margin="8,0,0,8">
                            <TextBlock Text="Client ID" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                            <TextBox x:Name="ClientIdTextBox" Margin="0,4,0,0" />
                        </StackPanel>

                        <StackPanel Grid.Column="0" Grid.Row="1" Grid.ColumnSpan="2">
                            <TextBlock Text="Client Secret" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                            <PasswordBox x:Name="ClientSecretBox" Margin="0,4,0,0" />
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Azure DevOps Settings -->
            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Azure DevOps" FontWeight="SemiBold" FontSize="16" Margin="0,0,0,8" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Column="0" Grid.Row="0" Margin="0,0,8,8">
                            <TextBlock Text="Organization" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                            <TextBox x:Name="AdoOrgTextBox" Margin="0,4,0,0" />
                        </StackPanel>

                        <StackPanel Grid.Column="1" Grid.Row="0" Margin="8,0,0,8">
                            <TextBlock Text="Project" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                            <TextBox x:Name="AdoProjectTextBox" Margin="0,4,0,0" />
                        </StackPanel>

                        <!-- NO PAT — Azure DevOps uses SSO only -->
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Snipe-IT Settings -->
            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Snipe-IT" FontWeight="SemiBold" FontSize="16" Margin="0,0,0,8" />
                    <StackPanel Margin="0,0,0,8">
                        <TextBlock Text="Base URL" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                        <TextBox x:Name="SnipeUrlTextBox" Margin="0,4,0,0" />
                    </StackPanel>
                    <StackPanel>
                        <TextBlock Text="API Key" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                        <PasswordBox x:Name="SnipeApiKeyBox" Margin="0,4,0,0" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- TDX Settings -->
            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="TeamDynamix" FontWeight="SemiBold" FontSize="16" Margin="0,0,0,8" />
                    <StackPanel Margin="0,0,0,8">
                        <TextBlock Text="Base URL" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                        <TextBox x:Name="TdxUrlTextBox" Margin="0,4,0,0" />
                    </StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,8,0">
                            <TextBlock Text="Username" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                            <TextBox x:Name="TdxUsernameTextBox" Margin="0,4,0,0" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="8,0,0,0">
                            <TextBlock Text="Password" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                            <PasswordBox x:Name="TdxPasswordBox" Margin="0,4,0,0" />
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Save Button -->
            <Button Content="Save Settings" HorizontalAlignment="Right"
                    Style="{StaticResource AccentButtonStyle}" Padding="24,8"
                    Click="OnSaveClicked" />

            <!-- Authentication Status Section -->
            <TextBlock Text="Authentication Status" FontWeight="SemiBold" FontSize="18" Margin="0,24,0,12" />

            <StackPanel x:Name="AuthCardsPanel">
                <!-- Cards are generated in code-behind -->
            </StackPanel>

            <Button Content="Refresh All" HorizontalAlignment="Right" Margin="0,8,0,0"
                    Click="OnRefreshAuthClicked" />

            <!-- About Section -->
            <Border Style="{StaticResource CardStyle}" Margin="0,24,0,16">
                <StackPanel>
                    <TextBlock Text="About" FontWeight="SemiBold" FontSize="16" Margin="0,0,0,8" />
                    <StackPanel Orientation="Horizontal" Margin="0,4">
                        <TextBlock Text="Version" Width="100" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                        <TextBlock x:Name="VersionText" Text="1.0.0" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,4">
                        <TextBlock Text="Platform" Width="100" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                        <TextBlock x:Name="PlatformText" Text="Windows" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,4">
                        <TextBlock Text="Architecture" Width="100" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                        <TextBlock x:Name="ArchitectureText" Text="" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,4">
                        <TextBlock Text=".NET Runtime" Width="100" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                        <TextBlock x:Name="RuntimeText" Text="" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
