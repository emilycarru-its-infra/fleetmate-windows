<Page x:Class="FleetMate.GUI.Views.Shared.DashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.modernwpf.com/2019"
      xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Row 0: Fixed top area -->
        <StackPanel Grid.Row="0" Margin="16,16,16,8">
            <!-- Header -->
            <DockPanel Margin="0,0,0,6">
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Top">
                    <ui:ProgressRing x:Name="HeaderProgress" IsActive="True" Width="18" Height="18"
                                     Margin="0,0,8,0" Visibility="Collapsed" />
                    <Button Content="Refresh" Click="OnRefreshClicked" Margin="0,0,8,0" />
                    <Button x:Name="AuthButton" Content="Authentication" Click="OnAuthClicked" />
                    <Popup x:Name="AuthPopup" PlacementTarget="{Binding ElementName=AuthButton}" Placement="Bottom"
                           StaysOpen="False" AllowsTransparency="True">
                        <Border Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}"
                                BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                                BorderThickness="1" CornerRadius="8" Width="480" MaxHeight="600"
                                Padding="0">
                            <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="580">
                                <StackPanel x:Name="AuthSystemsPanel" Margin="16" />
                            </ScrollViewer>
                        </Border>
                    </Popup>
                </StackPanel>
                <StackPanel>
                    <TextBlock Text="Dashboard" Style="{StaticResource TitleTextStyle}" Margin="0,0,0,2" />
                    <TextBlock Text="Fleet overview across all connected systems" Style="{StaticResource SubtitleTextStyle}" />
                </StackPanel>
            </DockPanel>

            <!-- Error Banner -->
            <Border x:Name="ErrorBanner" Visibility="Collapsed" Background="#33FF6600" CornerRadius="4" Padding="12,8" Margin="0,0,0,8">
                <DockPanel>
                    <Button DockPanel.Dock="Right" Content="Dismiss" Click="OnDismissErrorClicked"
                            VerticalAlignment="Center" Margin="12,0,0,0" />
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <ui:FontIcon Glyph="&#xE7BA;" FontSize="16" Margin="0,0,8,0" />
                        <TextBlock x:Name="ErrorBannerText" TextWrapping="Wrap"
                                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- Alert Pills -->
            <WrapPanel x:Name="AlertPillsPanel" Margin="0,0,0,6" />

            <!-- Loading indicator -->
            <StackPanel x:Name="LoadingPanel" Orientation="Horizontal" Margin="0,0,0,6" Visibility="Collapsed">
                <ui:ProgressRing IsActive="True" Width="20" Height="20" />
                <TextBlock Text="Loading dashboard data..." Margin="8,0,0,0" VerticalAlignment="Center"
                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
            </StackPanel>

            <!-- Connect Services Prompt -->
            <Border x:Name="ConnectServicesPrompt" Visibility="Collapsed" Style="{StaticResource CardStyle}" Margin="0,0,0,6">
                <StackPanel HorizontalAlignment="Center" Margin="24">
                    <ui:FontIcon Glyph="&#xE968;" FontSize="36" HorizontalAlignment="Center" Margin="0,0,0,8" />
                    <TextBlock Text="No services connected yet" FontSize="16" FontWeight="SemiBold" HorizontalAlignment="Center" />
                    <TextBlock Text="Configure your systems in Settings to see fleet data here."
                               HorizontalAlignment="Center" Margin="0,4,0,0"
                               Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                </StackPanel>
            </Border>

            <!-- KPI Strip -->
            <WrapPanel x:Name="KpiStrip" Margin="0,0,0,0" />
        </StackPanel>

        <!-- Row 1: Fill-height split panel -->
        <Grid Grid.Row="1" Margin="16,0,16,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Left 50%: Scrollable charts -->
            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <WrapPanel x:Name="ChartGrid" />
            </ScrollViewer>

            <!-- Divider -->
            <Rectangle Grid.Column="1" Width="1" Margin="8,0"
                       Fill="{DynamicResource SystemControlForegroundBaseLowBrush}" />

            <!-- Right 50%: Activity feed fills height -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Activity title -->
                <DockPanel Grid.Row="0" Margin="0,0,0,6">
                    <TextBlock Text="Recent Activity" Style="{StaticResource SectionHeaderStyle}" VerticalAlignment="Center" />
                </DockPanel>

                <!-- Filter chips -->
                <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled" Margin="0,0,0,8">
                    <StackPanel x:Name="ActivityFilterPanel" Orientation="Horizontal" />
                </ScrollViewer>

                <!-- Feed fills remaining height -->
                <Border Grid.Row="2" Style="{StaticResource CardStyle}" Padding="0">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" x:Name="ActivityScrollViewer">
                        <StackPanel>
                            <ItemsControl x:Name="ActivityFeed">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                                                BorderThickness="0,0,0,0.5" Padding="10,5" Cursor="Hand"
                                                MouseLeftButtonUp="OnActivityItemClicked" Tag="{Binding Tab}">
                                            <DockPanel>
                                                <TextBlock Text="{Binding Time}" DockPanel.Dock="Right" FontSize="10"
                                                           VerticalAlignment="Center" Margin="8,0,0,0"
                                                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                    <ui:FontIcon Glyph="{Binding IconGlyph}" FontSize="12" Margin="0,0,6,0"
                                                                 Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                                                    <TextBlock Text="{Binding Text}" FontSize="12" TextTrimming="CharacterEllipsis" />
                                                </StackPanel>
                                            </DockPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                                <ItemsControl.Style>
                                    <Style TargetType="ItemsControl">
                                        <Style.Triggers>
                                            <Trigger Property="HasItems" Value="False">
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate>
                                                            <TextBlock Text="Activity will appear once data loads." Padding="10,8"
                                                                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </ItemsControl.Style>
                            </ItemsControl>
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Page>
