<Page x:Class="FleetMate.GUI.Views.IdentityPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.modernwpf.com/2019">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header with inline toggle -->
        <DockPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="Identity" Style="{StaticResource TitleTextStyle}" DockPanel.Dock="Left" VerticalAlignment="Center" />
            <StackPanel Orientation="Horizontal" Margin="16,0,0,0" VerticalAlignment="Center">
                <RadioButton x:Name="GroupsRadio" Content="Groups" IsChecked="True" GroupName="IdentityTab" 
                             Checked="OnTabChanged" Margin="0,0,8,0" />
                <RadioButton x:Name="UsersRadio" Content="Users" GroupName="IdentityTab" 
                             Checked="OnTabChanged" />
            </StackPanel>
        </DockPanel>

        <!-- Content -->
        <Grid Grid.Row="1">
            <!-- Groups Content -->
            <Border x:Name="GroupsPanel" Style="{StaticResource CardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- Groups Search -->
                    <DockPanel Grid.Row="0" Margin="0,0,0,8">
                        <Button DockPanel.Dock="Right" x:Name="GroupsRefreshButton" Content="🔄 Refresh" 
                                Click="OnGroupsRefreshClicked" Margin="8,0,0,0" />
                        <TextBox x:Name="GroupsSearchBox" ui:ControlHelper.PlaceholderText="Filter groups..." 
                                 TextChanged="OnGroupsSearchChanged" />
                    </DockPanel>

                    <!-- Groups Loading -->
                    <StackPanel x:Name="GroupsLoadingPanel" Grid.Row="1" Visibility="Collapsed" 
                                HorizontalAlignment="Center" VerticalAlignment="Center">
                        <ui:ProgressRing IsActive="True" Width="40" Height="40" />
                        <TextBlock Text="Loading device groups..." Margin="0,8,0,0" />
                    </StackPanel>

                    <!-- Groups Not Configured -->
                    <TextBlock x:Name="GroupsNotConfiguredText" Grid.Row="1" Visibility="Collapsed"
                               Text="Microsoft Graph (Systems) is not configured."
                               Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                               VerticalAlignment="Center" HorizontalAlignment="Center" />

                    <!-- Groups List -->
                    <TreeView x:Name="GroupsTreeView" Grid.Row="1" />
                </Grid>
            </Border>

            <!-- Users Content -->
            <Border x:Name="UsersPanel" Style="{StaticResource CardStyle}" Visibility="Collapsed">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- Users Search -->
                    <DockPanel Grid.Row="0" Margin="0,0,0,8">
                        <Button DockPanel.Dock="Right" x:Name="UsersSearchButton" Content="🔍 Search" 
                                Click="OnUsersSearchClicked" Margin="8,0,0,0" />
                        <TextBox x:Name="UsersSearchBox" ui:ControlHelper.PlaceholderText="Search by email or name..." 
                                 KeyDown="OnUsersSearchKeyDown" />
                    </DockPanel>

                    <!-- Users Loading -->
                    <StackPanel x:Name="UsersLoadingPanel" Grid.Row="1" Visibility="Collapsed" 
                                HorizontalAlignment="Center" VerticalAlignment="Center">
                        <ui:ProgressRing IsActive="True" Width="40" Height="40" />
                        <TextBlock Text="Searching..." Margin="0,8,0,0" />
                    </StackPanel>

                    <!-- Users Not Configured -->
                    <TextBlock x:Name="UsersNotConfiguredText" Grid.Row="1" Visibility="Collapsed"
                               Text="Microsoft Graph is not configured. Set GRAPH_TENANT_ID and GRAPH_CLIENT_ID."
                               Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                               VerticalAlignment="Center" HorizontalAlignment="Center" />

                    <!-- Users Placeholder -->
                    <TextBlock x:Name="UsersPlaceholderText" Grid.Row="1" 
                               Text="Enter an email address or name to search for users"
                               Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                               VerticalAlignment="Center" HorizontalAlignment="Center" />

                    <!-- Users List -->
                    <ListView x:Name="UsersListView" Grid.Row="1" Visibility="Collapsed">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="4">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="👤 " FontSize="16" VerticalAlignment="Center" />
                                        <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" VerticalAlignment="Center" />
                                        <TextBlock x:Name="AccountBadge" Margin="8,0,0,0" FontSize="11" VerticalAlignment="Center"
                                                   Foreground="Green" Text="● Active" />
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                        <TextBlock Text="{Binding Mail}" FontSize="12" 
                                                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" 
                                                   Margin="0,0,12,0" />
                                        <TextBlock Text="{Binding JobTitle}" FontSize="12" 
                                                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" 
                                                   Margin="0,0,12,0" />
                                        <TextBlock Text="{Binding Department}" FontSize="12" 
                                                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                                    </StackPanel>
                                    <!-- Group Memberships -->
                                    <ItemsControl x:Name="GroupTags" ItemsSource="{Binding MemberOf}" Margin="0,4,0,0">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="#220078D4" 
                                                        CornerRadius="3" Padding="6,2" Margin="0,0,4,4">
                                                    <TextBlock Text="{Binding DisplayName}" FontSize="11" />
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>
