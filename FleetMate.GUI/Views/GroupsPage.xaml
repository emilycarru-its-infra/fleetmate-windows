<Page x:Class="FleetMate.GUI.Views.GroupsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.modernwpf.com/2019">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Text="Groups" Style="{StaticResource TitleTextStyle}" />
            <TextBlock Text="Entra ID groups" Style="{StaticResource SubtitleTextStyle}" />
        </StackPanel>

        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="0,16,0,0">
            <TextBlock Text="Group list will appear here once configured."
                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                       VerticalAlignment="Center" HorizontalAlignment="Center" />
        </Border>
    </Grid>
</Page>
