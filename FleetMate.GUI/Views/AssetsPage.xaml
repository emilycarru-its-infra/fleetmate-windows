<Page x:Class="FleetMate.GUI.Views.AssetsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.modernwpf.com/2019"
      Loaded="Page_Loaded">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock Text="Inventory" Style="{StaticResource TitleTextStyle}" />
                <TextBlock Text="Snipe-IT asset inventory management" Style="{StaticResource SubtitleTextStyle}" />
            </StackPanel>

            <ui:SimpleStackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                <Button Click="OnRefreshClicked" ToolTip="Refresh">
                    <ui:SymbolIcon Symbol="Refresh" />
                </Button>
            </ui:SimpleStackPanel>
        </Grid>

        <!-- Search -->
        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="0,16,0,0" Padding="12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBox x:Name="SearchBox" 
                         ui:ControlHelper.PlaceholderText="Search assets by name, tag, or serial..." 
                         Grid.Column="0"
                         TextChanged="SearchBox_TextChanged" />

                <TextBlock x:Name="AssetCountLabel" 
                           Grid.Column="1" 
                           Margin="16,0,0,0"
                           Style="{StaticResource CaptionTextBlockStyle}"
                           VerticalAlignment="Center" />
            </Grid>
        </Border>

        <!-- 60/40 split: Asset list + Detail sidebar -->
        <Grid Grid.Row="2" Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="6*" />
                <ColumnDefinition Width="4*" />
            </Grid.ColumnDefinitions>

            <!-- Asset List -->
            <ListView x:Name="AssetListView" 
                      Grid.Column="0"
                      BorderThickness="0"
                      SelectionMode="Single"
                      SelectionChanged="AssetListView_SelectionChanged">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="Asset Tag" Width="120"
                                        DisplayMemberBinding="{Binding AssetTag}" />
                        <GridViewColumn Header="Name" Width="200"
                                        DisplayMemberBinding="{Binding DisplayName}" />
                        <GridViewColumn Header="Serial" Width="150"
                                        DisplayMemberBinding="{Binding Serial}" />
                        <GridViewColumn Header="Model" Width="150">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Model.Name}" />
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="Status" Width="100">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding StatusLabel.Name}" />
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="Assigned To" Width="150">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding AssignedTo.Name}" />
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                    </GridView>
                </ListView.View>
            </ListView>

            <!-- Detail Sidebar -->
            <Border Grid.Column="1" 
                    Style="{StaticResource CardStyle}" 
                    Margin="16,0,0,0" Padding="16">
                
                <!-- No selection placeholder -->
                <TextBlock x:Name="DetailPlaceholder" 
                           Text="Select an asset to view details"
                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                           VerticalAlignment="Center" HorizontalAlignment="Center" />
            </Border>
            
            <!-- Detail content (overlays placeholder when visible) -->
            <Border Grid.Column="1" 
                    Style="{StaticResource CardStyle}" 
                    Margin="16,0,0,0" Padding="0"
                    x:Name="DetailPanel" Visibility="Collapsed">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16">
                    <ui:SimpleStackPanel Spacing="12">
                        <!-- Asset name + open in Snipe-IT -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="DetailAssetName" FontSize="18" FontWeight="Bold" TextWrapping="Wrap" />
                            <Button Grid.Column="1" Click="OnOpenInSnipeClicked" ToolTip="Open in Snipe-IT" Padding="6">
                                <TextBlock Text="🌐" FontSize="14" />
                            </Button>
                        </Grid>

                        <TextBlock x:Name="DetailAssetTag" FontSize="13" Opacity="0.7" />

                        <!-- Status -->
                        <StackPanel>
                            <TextBlock Text="Status" FontWeight="SemiBold" FontSize="12" Opacity="0.6" />
                            <TextBlock x:Name="DetailStatus" Margin="0,2,0,0" />
                        </StackPanel>

                        <!-- Assignment -->
                        <StackPanel x:Name="AssignmentSection">
                            <TextBlock Text="Assignment" FontWeight="SemiBold" FontSize="12" Opacity="0.6" />
                            <TextBlock x:Name="DetailAssignedName" Margin="0,2,0,0" />
                            <TextBlock x:Name="DetailAssignedUsername" FontSize="12" Opacity="0.7" />
                            <TextBlock x:Name="DetailAssignedEmployee" FontSize="12" Opacity="0.7" />
                        </StackPanel>

                        <!-- Re-Allocate Button -->
                        <Button x:Name="ReAllocateButton" Content="Re-Allocate" Click="OnReAllocateClicked" 
                                HorizontalAlignment="Stretch" Visibility="Collapsed" />

                        <!-- Hardware -->
                        <StackPanel>
                            <TextBlock Text="Hardware" FontWeight="SemiBold" FontSize="12" Opacity="0.6" />
                            <Grid Margin="0,4,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition />
                                    <RowDefinition />
                                    <RowDefinition />
                                    <RowDefinition />
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Serial:" FontSize="12" Opacity="0.7" Margin="0,0,8,2" />
                                <TextBlock x:Name="DetailSerial" Grid.Row="0" Grid.Column="1" FontSize="12" />
                                <Button Grid.Row="0" Grid.Column="2" Click="OnCopySerialClicked" ToolTip="Copy" Padding="2" Background="Transparent" BorderThickness="0">
                                    <TextBlock Text="📋" FontSize="10" />
                                </Button>

                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Model:" FontSize="12" Opacity="0.7" Margin="0,0,8,2" />
                                <TextBlock x:Name="DetailModel" Grid.Row="1" Grid.Column="1" FontSize="12" />

                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Category:" FontSize="12" Opacity="0.7" Margin="0,0,8,2" />
                                <TextBlock x:Name="DetailCategory" Grid.Row="2" Grid.Column="1" FontSize="12" />

                                <TextBlock Grid.Row="3" Grid.Column="0" Text="Manufacturer:" FontSize="12" Opacity="0.7" Margin="0,0,8,2" />
                                <TextBlock x:Name="DetailManufacturer" Grid.Row="3" Grid.Column="1" FontSize="12" />
                            </Grid>
                        </StackPanel>

                        <!-- Location -->
                        <StackPanel x:Name="LocationSection">
                            <TextBlock Text="Location" FontWeight="SemiBold" FontSize="12" Opacity="0.6" />
                            <TextBlock x:Name="DetailLocation" FontSize="12" Margin="0,2,0,0" />
                        </StackPanel>

                        <!-- Dates -->
                        <StackPanel>
                            <TextBlock Text="Dates" FontWeight="SemiBold" FontSize="12" Opacity="0.6" />
                            <Grid Margin="0,4,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition />
                                    <RowDefinition />
                                    <RowDefinition />
                                    <RowDefinition />
                                    <RowDefinition />
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Purchased:" FontSize="12" Opacity="0.7" Margin="0,0,8,2" />
                                <TextBlock x:Name="DetailPurchaseDate" Grid.Row="0" Grid.Column="1" FontSize="12" />

                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Last Checkout:" FontSize="12" Opacity="0.7" Margin="0,0,8,2" />
                                <TextBlock x:Name="DetailLastCheckout" Grid.Row="1" Grid.Column="1" FontSize="12" />

                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Last Audit:" FontSize="12" Opacity="0.7" Margin="0,0,8,2" />
                                <TextBlock x:Name="DetailLastAudit" Grid.Row="2" Grid.Column="1" FontSize="12" />

                                <TextBlock Grid.Row="3" Grid.Column="0" Text="Created:" FontSize="12" Opacity="0.7" Margin="0,0,8,2" />
                                <TextBlock x:Name="DetailCreated" Grid.Row="3" Grid.Column="1" FontSize="12" />

                                <TextBlock Grid.Row="4" Grid.Column="0" Text="Updated:" FontSize="12" Opacity="0.7" Margin="0,0,8,2" />
                                <TextBlock x:Name="DetailUpdated" Grid.Row="4" Grid.Column="1" FontSize="12" />
                            </Grid>
                        </StackPanel>

                        <!-- Notes -->
                        <StackPanel x:Name="NotesSection">
                            <TextBlock Text="Notes" FontWeight="SemiBold" FontSize="12" Opacity="0.6" />
                            <TextBlock x:Name="DetailNotes" FontSize="12" TextWrapping="Wrap" Margin="0,2,0,0" />
                        </StackPanel>

                        <!-- Custom Fields (dynamically populated) -->
                        <StackPanel x:Name="CustomFieldsSection">
                            <TextBlock Text="Custom Fields" FontWeight="SemiBold" FontSize="12" Opacity="0.6" />
                            <StackPanel x:Name="CustomFieldsContainer" Margin="0,4,0,0" />
                        </StackPanel>
                    </ui:SimpleStackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- Not Configured -->
        <TextBlock x:Name="NotConfiguredText"
                   Grid.Row="2"
                   Text="Snipe-IT is not configured. Please set SNIPE_URL and SNIPE_API_KEY."
                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                   VerticalAlignment="Center" HorizontalAlignment="Center"
                   Visibility="Collapsed" />

        <!-- Loading Overlay -->
        <Border x:Name="LoadingOverlay" 
                Grid.RowSpan="3" 
                Background="{DynamicResource SystemControlBackgroundAltHighBrush}" 
                Opacity="0.8"
                Visibility="Collapsed">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ui:ProgressRing IsActive="True" Width="40" Height="40" />
                <TextBlock Text="Loading assets..." Margin="0,12,0,0" />
            </StackPanel>
        </Border>
    </Grid>
</Page>
