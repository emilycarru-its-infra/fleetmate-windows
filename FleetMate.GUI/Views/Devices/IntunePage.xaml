<Page x:Class="FleetMate.GUI.Views.Devices.IntunePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="clr-namespace:FleetMate.GUI.Views.Devices"
      xmlns:ui="http://schemas.modernwpf.com/2019">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Grid.Column="0">
            <TextBlock Text="Management" Style="{StaticResource TitleTextStyle}" />
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="MDM devices (Intune, Jamf, etc.)" Style="{StaticResource SubtitleTextStyle}" />
                <TextBlock x:Name="SelectionCountText" Margin="8,0,0,0" Foreground="{DynamicResource SystemControlForegroundAccentBrush}" FontWeight="SemiBold" />
            </StackPanel>
        </StackPanel>

        <!-- Toolbar -->
        <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top">
            <CheckBox x:Name="NonCompliantOnlyCheckBox" Content="Non-Compliant Only" Margin="0,0,16,0" Checked="OnFilterChanged" Unchecked="OnFilterChanged" />
            <TextBlock Text="Platform:" VerticalAlignment="Center" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" Margin="0,0,4,0" />
            <ComboBox x:Name="PlatformFilterComboBox" Width="110" Margin="0,0,8,0" SelectionChanged="OnPlatformFilterChanged">
                <ComboBoxItem Content="All" IsSelected="True" />
            </ComboBox>
            <ComboBox x:Name="SortComboBox" Width="120" Margin="0,0,8,0" SelectionChanged="OnSortChanged">
                <ComboBoxItem Content="Serial" IsSelected="True" />
                <ComboBoxItem Content="Name" />
                <ComboBoxItem Content="Compliance" />
                <ComboBoxItem Content="OS" />
                <ComboBoxItem Content="User" />
                <ComboBoxItem Content="Last Sync" />
            </ComboBox>
            <Button x:Name="SortDirectionButton" Content="↑" Width="32" Margin="0,0,8,0" Click="OnSortDirectionClicked" ToolTip="Toggle sort direction" />
            <Button x:Name="ActionsButton" Content="⚡ Actions" Margin="0,0,8,0" Click="OnActionsClicked" IsEnabled="False" />
            <Button x:Name="RefreshButton" Content="🔄 Refresh" Click="OnRefreshClicked" />
        </StackPanel>

        <!-- Search and Select -->
        <Grid Grid.Row="1" Grid.ColumnSpan="2" Margin="0,16,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBox x:Name="SearchBox" ui:ControlHelper.PlaceholderText="Search devices..." TextChanged="OnSearchChanged" />
            <Button Grid.Column="1" Content="Select All" Margin="8,0,0,0" Click="OnSelectAllClicked" />
            <Button Grid.Column="2" x:Name="ClearSelectionButton" Content="Clear" Margin="8,0,0,0" Click="OnClearSelectionClicked" IsEnabled="False" />
        </Grid>

        <!-- Main Content -->
        <Grid Grid.Row="2" Grid.ColumnSpan="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition x:Name="ActionsPanelColumn" Width="0" />
                <ColumnDefinition x:Name="DetailPanelColumn" Width="0" />
            </Grid.ColumnDefinitions>

            <!-- Device List -->
            <Border Grid.Column="0" Style="{StaticResource CardStyle}">
                <Grid>
                    <!-- Loading indicator -->
                    <StackPanel x:Name="LoadingPanel" Visibility="Collapsed" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <ui:ProgressRing IsActive="True" Width="40" Height="40" />
                        <TextBlock Text="Loading devices..." Margin="0,8,0,0" />
                    </StackPanel>

                    <!-- Not configured message -->
                    <TextBlock x:Name="NotConfiguredText" Visibility="Collapsed"
                               Text="Microsoft Graph is not configured. Set GRAPH_TENANT_ID and credentials in your config."
                               Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                               VerticalAlignment="Center" HorizontalAlignment="Center" TextWrapping="Wrap" />

                    <!-- Device DataGrid -->
                    <DataGrid x:Name="DevicesDataGrid"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              SelectionMode="Extended"
                              SelectionChanged="OnDeviceSelectionChanged"
                              GridLinesVisibility="Horizontal"
                              HeadersVisibility="Column"
                              CanUserSortColumns="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Serial" Binding="{Binding SerialNumber}" Width="120" />
                            <DataGridTextColumn Header="Name" Binding="{Binding DeviceName}" Width="180" />
                            <DataGridTemplateColumn Header="Compliance" Width="120">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <Ellipse Width="10" Height="10" Margin="0,0,6,0">
                                                <Ellipse.Style>
                                                    <Style TargetType="Ellipse">
                                                        <Setter Property="Fill" Value="Gray" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding ComplianceState}" Value="compliant">
                                                                <Setter Property="Fill" Value="Green" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding ComplianceState}" Value="noncompliant">
                                                                <Setter Property="Fill" Value="Red" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding ComplianceState}" Value="inGracePeriod">
                                                                <Setter Property="Fill" Value="Orange" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Ellipse.Style>
                                            </Ellipse>
                                            <TextBlock Text="{Binding ComplianceState}" />
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="OS" Binding="{Binding OperatingSystem}" Width="100" />
                            <DataGridTextColumn Header="Version" Binding="{Binding OsVersion}" Width="100" />
                            <DataGridTextColumn Header="User" Binding="{Binding UserDisplayName}" Width="150" />
                            <DataGridTextColumn Header="Last Sync" Binding="{Binding LastSyncDateTime, StringFormat='{}{0:yyyy-MM-dd HH:mm}'}" Width="140" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <!-- Actions Panel -->
            <Border x:Name="ActionsPanel" Grid.Column="1" Style="{StaticResource CardStyle}" Margin="16,0,0,0" Visibility="Collapsed">
                <Grid Width="300">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- Panel Header -->
                    <Grid Grid.Row="0" Margin="0,0,0,8">
                        <TextBlock Text="Device Actions" FontWeight="Bold" FontSize="16" />
                        <Button Content="✕" HorizontalAlignment="Right" Width="28" Height="28" Click="OnCloseActionsPanel" />
                    </Grid>

                    <!-- Selection Summary -->
                    <StackPanel Grid.Row="1" Margin="0,0,0,8">
                        <TextBlock x:Name="SelectedDevicesText" FontWeight="SemiBold" />
                        <TextBlock x:Name="SelectedDeviceNamesText" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" TextTrimming="CharacterEllipsis" />
                    </StackPanel>

                    <!-- Action Message -->
                    <Border x:Name="ActionMessageBorder" Grid.Row="2" Visibility="Collapsed" Padding="8" Margin="0,0,0,8" CornerRadius="4">
                        <StackPanel Orientation="Horizontal">
                            <ui:ProgressRing x:Name="ActionProgressRing" IsActive="False" Width="16" Height="16" Margin="0,0,8,0" />
                            <TextBlock x:Name="ActionMessageText" TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <!-- Actions ScrollViewer -->
                    <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <!-- Sync Section -->
                            <Expander Header="🔄 Sync Device" IsExpanded="True">
                                <StackPanel Margin="8">
                                    <TextBlock Text="Force devices to check in with Intune and re-evaluate policies and app assignments." 
                                               TextWrapping="Wrap" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" Margin="0,0,0,8" />
                                    <Button Content="Sync Now" Click="OnSyncClicked" HorizontalAlignment="Stretch" />
                                </StackPanel>
                            </Expander>

                            <!-- Restart Section -->
                            <Expander Header="🔌 Restart Device">
                                <StackPanel Margin="8">
                                    <TextBlock Text="Immediately restart the selected devices. Active user sessions will be terminated." 
                                               TextWrapping="Wrap" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" Margin="0,0,0,8" />
                                    <Button Content="Restart" Click="OnRestartClicked" HorizontalAlignment="Stretch" Background="Orange" />
                                </StackPanel>
                            </Expander>

                            <!-- Lock Section -->
                            <Expander Header="🔒 Lock Device">
                                <StackPanel Margin="8">
                                    <TextBlock Text="Remotely lock devices. Enter a PIN for supported devices." 
                                               TextWrapping="Wrap" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" Margin="0,0,0,8" />
                                    <TextBox x:Name="LockPinTextBox" ui:ControlHelper.PlaceholderText="PIN (optional)" Margin="0,0,0,8" />
                                    <Button Content="Lock Device" Click="OnLockClicked" HorizontalAlignment="Stretch" Background="Red" Foreground="White" />
                                </StackPanel>
                            </Expander>

                            <!-- Retire Section -->
                            <Expander Header="➖ Retire Device">
                                <StackPanel Margin="8">
                                    <TextBlock Text="Remove company data and unenroll the selected devices. Personal data is left intact."
                                               TextWrapping="Wrap" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" Margin="0,0,0,8" />
                                    <Button Content="Retire Device" Click="OnRetireClicked" HorizontalAlignment="Stretch" Background="Red" Foreground="White" />
                                </StackPanel>
                            </Expander>

                            <!-- Wipe Section -->
                            <Expander Header="🗑 Wipe Device">
                                <StackPanel Margin="8">
                                    <TextBlock Text="Factory-reset the selected devices. This cannot be undone."
                                               TextWrapping="Wrap" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" Margin="0,0,0,8" />
                                    <Button Content="Wipe Device" Click="OnWipeClicked" HorizontalAlignment="Stretch" Background="Red" Foreground="White" />
                                </StackPanel>
                            </Expander>

                            <!-- App Reinstall Section -->
                            <Expander Header="📦 Reinstall App">
                                <StackPanel Margin="8">
                                    <TextBlock Text="Trigger app reinstallation by initiating a device sync." 
                                               TextWrapping="Wrap" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" Margin="0,0,0,8" />
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBox x:Name="AppSearchBox" ui:ControlHelper.PlaceholderText="Search apps..." />
                                        <Button Grid.Column="1" Content="🔍" Width="32" Margin="4,0,0,0" Click="OnSearchAppsClicked" />
                                    </Grid>
                                    <ComboBox x:Name="AppComboBox" ui:ControlHelper.PlaceholderText="Select an app..." HorizontalAlignment="Stretch" Margin="0,0,0,8" />
                                    <Button Content="Trigger Reinstall" Click="OnReinstallAppClicked" HorizontalAlignment="Stretch" />
                                </StackPanel>
                            </Expander>

                            <!-- OS Update Section -->
                            <Expander Header="⬆️ OS Update">
                                <StackPanel Margin="8">
                                    <TextBlock Text="Trigger OS update check. Updates are installed based on update policies." 
                                               TextWrapping="Wrap" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" Margin="0,0,0,8" />
                                    <Button Content="Check for Updates" Click="OnCheckUpdatesClicked" HorizontalAlignment="Stretch" />
                                </StackPanel>
                            </Expander>

                            <!-- Cimian Push Section -->
                            <Expander Header="⚡ Push Cimian Run">
                                <StackPanel Margin="8">
                                    <TextBlock Text="Trigger an immediate Cimian managed software update on selected devices. Creates a .cimian.headless trigger file via Intune remediation. CimianWatcher picks it up within 10 seconds." 
                                               TextWrapping="Wrap" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" Margin="0,0,0,8" />
                                    <Button Content="Push Cimian Run" Click="OnPushCimianClicked" HorizontalAlignment="Stretch" 
                                            Background="{DynamicResource SystemControlForegroundAccentBrush}" Foreground="White" />
                                </StackPanel>
                            </Expander>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>
            <!-- Device Detail Panel -->
            <local:DeviceDetailPanel x:Name="DeviceDetail" Grid.Column="2" Margin="16,0,0,0" Visibility="Collapsed" />
        </Grid>
    </Grid>
</Page>
