# FleetMate Environment Variables
# Copy to ~/.fleetmate/.env or project root .env and customize
#
# IMPORTANT: Never commit actual values to source control!
# All values should come from a key vault or secure secrets manager.

# ================================
# ReportMate API (fleet monitoring)
# ================================
REPORTMATE_URL=
REPORTMATE_PASSPHRASE=

# ================================
# Snipe-IT API (asset management)
# ================================
SNIPE_URL=
SNIPE_API_KEY=

# ================================
# Microsoft Graph (Intune/Entra)
# ================================
GRAPH_TENANT_ID=
GRAPH_CLIENT_ID=
GRAPH_CLIENT_SECRET=      # Optional - uses Azure CLI SSO if not set

# ================================
# Azure DevOps (work items)
# ================================
DEVOPS_ORGANIZATION=
DEVOPS_PROJECT=
DEVOPS_PAT=               # Optional - uses Azure CLI SSO if not set

# ================================
# TeamDynamix (TDX) tickets
# ================================
TDX_BASE_URL=
TDX_APP_ID=

# TDX Authentication - choose one method:
# Admin auth (preferred for elevated operations):
TDX_BEID=
TDX_WEB_SERVICES_KEY=

# Regular auth (fallback):
TDX_USERNAME=
TDX_PASSWORD=

# Optional: Load TDX credentials from Key Vault
TDX_KEY_VAULT_NAME=

# ================================
# SSH Configuration
# ================================
SSH_HOST=
SSH_USER=
SSH_KEY_PATH=
# Or load from Key Vault:
SECURE_SHELL_PRIVATE_KEY=
