<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="FleetMate.WinUI.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer>
        <StackPanel Padding="32" Spacing="20" VerticalAlignment="Top">
            <TextBlock Text="Settings" Style="{StaticResource TitleLargeTextBlockStyle}"/>

            <!-- Modules -->
            <TextBlock Text="Modules" Style="{StaticResource SubtitleTextBlockStyle}"/>
            <TextBlock Text="A module is available when its service is configured below."
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="13"/>
            <ItemsControl x:Name="ModulesList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid Padding="4,6" ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding Caption}" FontSize="12"
                                           Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                            </StackPanel>
                            <ToggleSwitch Grid.Column="1" IsOn="{Binding IsConfigured}" IsEnabled="False"/>
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Authentication -->
            <Grid Margin="0,12,0,0">
                <TextBlock Text="Authentication" Style="{StaticResource SubtitleTextBlockStyle}"
                           VerticalAlignment="Center"/>
                <Button x:Name="RefreshButton" Content="Refresh All" Click="RefreshButton_Click"
                        HorizontalAlignment="Right" VerticalAlignment="Center"/>
            </Grid>
            <TextBlock x:Name="EmptyHint"
                       Text="No services are configured. Configure credentials to connect FleetMate to your systems."
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       Visibility="Collapsed"/>
            <GridView x:Name="AuthList" SelectionMode="None" IsItemClickEnabled="False"
                      ItemTemplate="{StaticResource AuthCardTemplate}"/>
        </StackPanel>
    </ScrollViewer>
</Page>
