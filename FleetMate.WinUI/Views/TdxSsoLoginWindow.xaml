<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="FleetMate.WinUI.Views.TdxSsoLoginWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Sign in to TeamDynamix">

    <Grid RowSpacing="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="StatusText" Grid.Row="0" Margin="16,10"
                   Text="Loading TeamDynamix sign-in…" FontSize="13"/>

        <WebView2 x:Name="WebView" Grid.Row="1"/>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right"
                    Spacing="8" Margin="16,10">
            <ProgressRing x:Name="Busy" IsActive="True" Width="18" Height="18" VerticalAlignment="Center"/>
            <Button x:Name="CancelButton" Content="Cancel" Click="Cancel_Click"/>
        </StackPanel>
    </Grid>
</Window>
