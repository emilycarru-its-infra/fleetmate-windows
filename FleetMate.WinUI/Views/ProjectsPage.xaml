<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="FleetMate.WinUI.Views.ProjectsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Padding="24" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock Text="Projects" Style="{StaticResource TitleLargeTextBlockStyle}"/>
                <TextBlock x:Name="CountText" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="13"/>
            </StackPanel>
            <TextBox x:Name="SearchBox" Grid.Column="1" PlaceholderText="Search title, type, state, assignee, #id…"
                     VerticalAlignment="Bottom" TextChanged="SearchBox_TextChanged"/>
            <Button x:Name="RefreshButton" Grid.Column="2" Content="Refresh" Click="RefreshButton_Click"
                    VerticalAlignment="Bottom"/>
        </Grid>

        <!-- Master + detail -->
        <Grid Grid.Row="1" ColumnSpacing="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="400"/>
            </Grid.ColumnDefinitions>

            <!-- List -->
            <Border Grid.Column="0" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Padding="16,10" ColumnSpacing="8"
                          Background="{ThemeResource SubtleFillColorSecondaryBrush}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="0.8*"/>
                            <ColumnDefinition Width="3*"/>
                            <ColumnDefinition Width="1.3*"/>
                            <ColumnDefinition Width="1.3*"/>
                            <ColumnDefinition Width="1.6*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="ID" FontWeight="SemiBold" FontSize="12"/>
                        <TextBlock Grid.Column="1" Text="Title" FontWeight="SemiBold" FontSize="12"/>
                        <TextBlock Grid.Column="2" Text="Type" FontWeight="SemiBold" FontSize="12"/>
                        <TextBlock Grid.Column="3" Text="State" FontWeight="SemiBold" FontSize="12"/>
                        <TextBlock Grid.Column="4" Text="Assignee" FontWeight="SemiBold" FontSize="12"/>
                    </Grid>

                    <ProgressRing x:Name="LoadingRing" Grid.Row="1" IsActive="False"
                                  Width="36" Height="36" HorizontalAlignment="Center" VerticalAlignment="Center"/>

                    <ListView x:Name="WorkItemList" Grid.Row="1" SelectionMode="Single"
                              SelectionChanged="WorkItemList_SelectionChanged"
                              HorizontalContentAlignment="Stretch">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Padding" Value="16,8"/>
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="0.8*"/>
                                        <ColumnDefinition Width="3*"/>
                                        <ColumnDefinition Width="1.3*"/>
                                        <ColumnDefinition Width="1.3*"/>
                                        <ColumnDefinition Width="1.6*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding IdText}"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                    <TextBlock Grid.Column="1" Text="{Binding Title}" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Grid.Column="2" Text="{Binding Type}" FontSize="12"
                                               TextTrimming="CharacterEllipsis"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                    <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="6">
                                        <Ellipse Width="9" Height="9" Fill="{Binding StateBrush}" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding State}" FontSize="12" VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                    <TextBlock Grid.Column="4" Text="{Binding Assignee}" TextTrimming="CharacterEllipsis"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>

            <!-- Detail -->
            <Border Grid.Column="1" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <ScrollViewer>
                    <StackPanel Padding="20" Spacing="6">
                        <TextBlock x:Name="EmptyDetail" Text="Select a work item to see details."
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <StackPanel x:Name="DetailPanel" Spacing="10" Visibility="Collapsed">
                            <TextBlock x:Name="DetailId" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <TextBlock x:Name="DetailTitle" Style="{StaticResource SubtitleTextBlockStyle}" TextWrapping="Wrap"/>

                            <TextBlock Text="Details" FontWeight="SemiBold" Margin="0,6,0,0"/>
                            <StackPanel x:Name="DetailRows" Spacing="3"/>

                            <TextBlock Text="Description" FontWeight="SemiBold" Margin="0,10,0,0"/>
                            <TextBlock x:Name="DetailDescription" TextWrapping="Wrap" FontSize="13"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</Page>
