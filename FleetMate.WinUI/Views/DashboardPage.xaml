<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="FleetMate.WinUI.Views.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer>
        <StackPanel Padding="32" Spacing="20" VerticalAlignment="Top">
            <Grid>
                <StackPanel>
                    <TextBlock Text="Dashboard" Style="{StaticResource TitleLargeTextBlockStyle}"/>
                    <TextBlock Text="Connected service authentication"
                               Style="{StaticResource BodyStrongTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                </StackPanel>
                <Button x:Name="RefreshButton" Content="Refresh" Click="RefreshButton_Click"
                        HorizontalAlignment="Right" VerticalAlignment="Top"/>
            </Grid>

            <TextBlock x:Name="EmptyHint"
                       Text="No services are configured on this device. Add credentials in Settings."
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       Visibility="Collapsed"/>

            <GridView x:Name="AuthList" SelectionMode="None" IsItemClickEnabled="False"
                      ItemTemplate="{StaticResource AuthCardTemplate}"/>
        </StackPanel>
    </ScrollViewer>
</Page>
