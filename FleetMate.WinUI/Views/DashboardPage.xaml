<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="FleetMate.WinUI.Views.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer>
        <StackPanel Padding="32" Spacing="20" VerticalAlignment="Top">
            <Grid>
                <StackPanel>
                    <TextBlock Text="Dashboard" Style="{StaticResource TitleLargeTextBlockStyle}"/>
                    <TextBlock Text="Connected service authentication"
                               Style="{StaticResource BodyStrongTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                </StackPanel>
                <Button x:Name="RefreshButton" Content="Refresh" Click="RefreshButton_Click"
                        HorizontalAlignment="Right" VerticalAlignment="Top"/>
            </Grid>

            <TextBlock x:Name="EmptyHint"
                       Text="No services are configured on this device. Add credentials in Settings."
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       Visibility="Collapsed"/>

            <GridView x:Name="AuthList" SelectionMode="None" IsItemClickEnabled="False">
                <GridView.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1" CornerRadius="8"
                                Padding="16" Margin="0,0,12,12" Width="300">
                            <StackPanel Spacing="8">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <FontIcon Glyph="{Binding Icon}" FontSize="18"/>
                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Ellipse Width="10" Height="10" Fill="{Binding StatusBrush}"
                                             VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding StatusLabel}"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                               FontSize="13" VerticalAlignment="Center"
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                                <TextBlock Text="{Binding User}" FontSize="12"
                                           Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                           Visibility="{Binding UserVisibility}"/>
                                <TextBlock Text="{Binding Category}" FontSize="11"
                                           Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </GridView.ItemTemplate>
            </GridView>
        </StackPanel>
    </ScrollViewer>
</Page>
