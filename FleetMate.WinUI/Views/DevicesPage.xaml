<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="FleetMate.WinUI.Views.DevicesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Padding="24" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock Text="Devices" Style="{StaticResource TitleLargeTextBlockStyle}"/>
                <TextBlock x:Name="CountText" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="13"/>
            </StackPanel>
            <TextBox x:Name="SearchBox" Grid.Column="1" PlaceholderText="Search name, serial, user, OS…"
                     VerticalAlignment="Bottom" TextChanged="SearchBox_TextChanged"/>
            <Button x:Name="RefreshButton" Grid.Column="2" Content="Refresh" Click="RefreshButton_Click"
                    VerticalAlignment="Bottom"/>
        </Grid>

        <!-- Master + detail -->
        <Grid Grid.Row="1" ColumnSpacing="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="400"/>
            </Grid.ColumnDefinitions>

            <!-- List -->
            <Border Grid.Column="0" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Action toolbar -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8" Padding="12,10"
                                Background="{ThemeResource LayerFillColorDefaultBrush}">
                        <Button x:Name="SyncButton" Content="Sync" Click="Sync_Click" IsEnabled="False"/>
                        <Button x:Name="RestartButton" Content="Restart" Click="Restart_Click" IsEnabled="False"/>
                        <Button x:Name="LockButton" Content="Lock" Click="Lock_Click" IsEnabled="False"/>
                        <Button x:Name="RetireButton" Content="Retire" Click="Retire_Click" IsEnabled="False"/>
                        <Button x:Name="WipeButton" Content="Wipe" Click="Wipe_Click" IsEnabled="False"/>
                        <TextBlock x:Name="SelectionText" VerticalAlignment="Center" Margin="8,0,0,0"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="13"/>
                    </StackPanel>

                    <!-- Column header -->
                    <Grid Grid.Row="1" Padding="16,10" ColumnSpacing="8"
                          Background="{ThemeResource SubtleFillColorSecondaryBrush}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="1.5*"/>
                            <ColumnDefinition Width="1.3*"/>
                            <ColumnDefinition Width="1.5*"/>
                            <ColumnDefinition Width="1.5*"/>
                            <ColumnDefinition Width="1.3*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Name" FontWeight="SemiBold" FontSize="12"/>
                        <TextBlock Grid.Column="1" Text="Serial" FontWeight="SemiBold" FontSize="12"/>
                        <TextBlock Grid.Column="2" Text="Compliance" FontWeight="SemiBold" FontSize="12"/>
                        <TextBlock Grid.Column="3" Text="OS" FontWeight="SemiBold" FontSize="12"/>
                        <TextBlock Grid.Column="4" Text="User" FontWeight="SemiBold" FontSize="12"/>
                        <TextBlock Grid.Column="5" Text="Last Sync" FontWeight="SemiBold" FontSize="12"/>
                    </Grid>

                    <ProgressRing x:Name="LoadingRing" Grid.Row="2" IsActive="False"
                                  Width="36" Height="36" HorizontalAlignment="Center" VerticalAlignment="Center"/>

                    <ListView x:Name="DeviceList" Grid.Row="2" SelectionMode="Extended"
                              SelectionChanged="DeviceList_SelectionChanged"
                              HorizontalContentAlignment="Stretch">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Padding" Value="16,8"/>
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="2*"/>
                                        <ColumnDefinition Width="1.5*"/>
                                        <ColumnDefinition Width="1.3*"/>
                                        <ColumnDefinition Width="1.5*"/>
                                        <ColumnDefinition Width="1.5*"/>
                                        <ColumnDefinition Width="1.3*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding Name}" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Grid.Column="1" Text="{Binding Serial}" TextTrimming="CharacterEllipsis"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                    <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="6">
                                        <Ellipse Width="9" Height="9" Fill="{Binding ComplianceBrush}" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding Compliance}" FontSize="12" VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                    <TextBlock Grid.Column="3" Text="{Binding Os}" TextTrimming="CharacterEllipsis"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                    <TextBlock Grid.Column="4" Text="{Binding User}" TextTrimming="CharacterEllipsis"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                    <TextBlock Grid.Column="5" Text="{Binding LastSync}" FontSize="12"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>

            <!-- Detail -->
            <Border Grid.Column="1" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <ScrollViewer>
                    <StackPanel Padding="20" Spacing="6">
                        <TextBlock x:Name="EmptyDetail" Text="Select a device to see details."
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <TextBlock x:Name="MultiDetail" Visibility="Collapsed"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

                        <StackPanel x:Name="DetailPanel" Spacing="10" Visibility="Collapsed">
                            <TextBlock x:Name="DetailName" Style="{StaticResource SubtitleTextBlockStyle}" TextWrapping="Wrap"/>

                            <TextBlock Text="Summary" FontWeight="SemiBold" Margin="0,6,0,0"/>
                            <StackPanel x:Name="SummaryRows" Spacing="3"/>

                            <TextBlock Text="Compliance policies" FontWeight="SemiBold" Margin="0,10,0,0"/>
                            <ProgressRing x:Name="ComplianceRing" IsActive="False" Width="20" Height="20" HorizontalAlignment="Left"/>
                            <ItemsControl x:Name="ComplianceList"/>
                            <TextBlock x:Name="ComplianceEmpty" Text="No policy states." FontSize="12"
                                       Foreground="{ThemeResource TextFillColorTertiaryBrush}" Visibility="Collapsed"/>

                            <TextBlock Text="Detected apps" FontWeight="SemiBold" Margin="0,10,0,0"/>
                            <ProgressRing x:Name="AppsRing" IsActive="False" Width="20" Height="20" HorizontalAlignment="Left"/>
                            <ItemsControl x:Name="AppsList"/>
                            <TextBlock x:Name="AppsEmpty" Text="No detected apps." FontSize="12"
                                       Foreground="{ThemeResource TextFillColorTertiaryBrush}" Visibility="Collapsed"/>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</Page>
